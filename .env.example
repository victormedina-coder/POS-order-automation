# ── Shopify por marca ─────────────────────────────────────────────────────────

# Ariat — auth estático (token fijo de Admin API)
ARIAT_SHOPIFY_STORE=
ARIAT_SHOPIFY_ACCESS_TOKEN=

# Stetson — auth OAuth client_credentials (ya NO usa *_ACCESS_TOKEN)
# Crear Custom App en Shopify Admin con flujo client_credentials habilitado
# y scopes: read_orders (+ los demás que use el exportador).
STETSON_SHOPIFY_STORE=
STETSON_SHOPIFY_CLIENT_ID=
STETSON_SHOPIFY_CLIENT_SECRET=

# Western Brothers — auth OAuth client_credentials (ya NO usa *_ACCESS_TOKEN)
# Mismos pasos que Stetson en su propio Shopify Admin.
WB_SHOPIFY_STORE=
WB_SHOPIFY_CLIENT_ID=
WB_SHOPIFY_CLIENT_SECRET=

# ── Shopify legacy (se eliminan en Etapa 7) ───────────────────────────────────
# SHOPIFY_STORE=
# SHOPIFY_ACCESS_TOKEN=

# ── General ───────────────────────────────────────────────────────────────────
ALLOWED_DOMAIN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=
DATABASE_PATH=
PORT=
BASE_URL=

# Facturama (global/compartida — opcional: si no se configuran, la columna UUID queda vacía para llenado manual)
FACTURAMA_USER=
FACTURAMA_PASS=
FACTURAMA_BASE_URL=
